# ============================================
# Python .gitignore
# Proyecto: Dinámica Orbital Kepleriana
# ============================================

# --- Bytecode y caché de Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Entornos virtuales ---
.venv/
venv/
ENV/
env/
.env

# --- Distribución / Empaquetado ---
dist/
build/
*.egg-info/
*.egg
*.whl
*.tar.gz

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*.ipynb_checkpoints
Untitled*.ipynb

# --- IDEs y editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# --- Sistema operativo ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Pytest ---
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- MyPy ---
.mypy_cache/
dmypy.json

# --- Tox ---
.tox/

# --- Ruff / Linting ---
.ruff_cache/

# --- Datos y archivos temporales ---
*.log
*.tmp
*.bak
*.orig
*.csv
!data/*.csv

# --- Archivos de entorno ---
.env
.env.local
.env.*.local
